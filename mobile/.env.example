# MaizAI Mobile — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local.

# Base URL of the MaizAI web back-end.
# Android emulator:  http://10.0.2.2:3000
# Physical device:   http://<your-machine-ip>:3000
# Production:        https://maizai.vercel.app
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Support address shown in the in-app feedback / debug screens.
EXPO_PUBLIC_SUPPORT_EMAIL=you@example.com

# Set to "true" to enable the in-app debug tools (debug screen + floating
# button). Leave unset/false for production-style builds.
EXPO_PUBLIC_DEBUG_MODE=false
