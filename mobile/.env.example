# MaizAI Mobile — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local.

# Base URL of the MaizAI web back-end.
# Android emulator:  http://10.0.2.2:3000
# Physical device:   http://<your-machine-ip>:3000
# Production:        https://your-vercel-app.vercel.app
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Cloudinary — go to https://cloudinary.com/console and find these values.
# The upload preset must be configured as "Unsigned" in the Cloudinary dashboard.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=maizai_unsigned
