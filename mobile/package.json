    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-camera": "^56.0.8",
    "expo-constants": "^56.0.18",
    "expo-crypto": "^56.0.4",
    "expo-file-system": "^56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "^56.0.3",
    "expo-image": "^56.0.11",
    "expo-image-manipulator": "^56.0.19",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "^56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "^56.0.5",
    "expo-status-bar": "~56.0.4",
    "jpeg-js": "^0.4.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jpeg-js": "^0.3.0",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-preset-expo": "~56.0.15",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "node scripts/ndk27-fix.js",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:log": "powershell -Command \"expo run:android 2>&1 | Tee-Object -FilePath \\\"../android-build-$(Get-Date -Format 'yyyyMMdd_HHmmss').log\\\"\"",
    "studio": "powershell -Command \"Start-Process 'C:\\Program Files\\Android\\Android Studio\\bin\\studio64.exe' -ArgumentList (Resolve-Path android).Path\"",
    "build:preview": "eas build --platform android --profile preview",
    "build:production": "eas build --platform android --profile production",
    "install:device": "powershell -File scripts/install-device.ps1",
    "logs:crash": "powershell -File scripts/crash-log.ps1",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "overrides": {
    "react-native-worklets": "$react-native-worklets",
    "react-dom": "19.2.3"
  }
}
