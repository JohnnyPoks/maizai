# Database (Neon in production, local PostgreSQL in development)
DATABASE_URL="postgresql://user:password@localhost:5432/maizai"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# HiveMQ MQTT
MQTT_HOST=""
MQTT_PORT="8883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TOPIC_SENSOR_TELEMETRY="maizai/sensors/+/telemetry"

# Sensor node authentication (never expose in client-side code)
SENSOR_INGEST_TOKEN="generate-secure-random-token"
