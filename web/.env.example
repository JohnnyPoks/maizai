# ─────────────────────────────────────────────────────────────
# MaizAI WEB back-end environment variables
# (Mobile app variables live in mobile/.env.local and are prefixed
#  EXPO_PUBLIC_* — keep the two projects separate.)
# ─────────────────────────────────────────────────────────────

# --- Database (Neon in production, local PostgreSQL in development) ---
DATABASE_URL="postgresql://user:password@localhost:5432/maizai"

# --- Authentication (NextAuth) ---
# In production set NEXTAUTH_URL to the deployed origin, e.g. https://maizai.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- Cloudinary (image storage) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Resend (transactional email) ---
RESEND_API_KEY=""
# Sender shown to recipients. onboarding@resend.dev works without DNS setup.
RESEND_FROM_EMAIL="MaizAI <onboarding@resend.dev>"
# Where access-request and bug-report notifications are sent.
SUPER_ADMIN_EMAIL="your-email@example.com"

# --- Sensor node ingest (Phase 2 — never expose client-side) ---
SENSOR_INGEST_TOKEN="generate-secure-random-token"

# --- HiveMQ MQTT (Phase 2 — optional, only when the sensor node is deployed) ---
MQTT_HOST=""
MQTT_PORT="8883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TOPIC_SENSOR_TELEMETRY="maizai/sensors/+/telemetry"
